  - name: Phase 2 — Act
    artifact: the change applied, scoped to Phase 1's files
    acceptance: "\`git diff\` is non-empty and touches only the files named in Phase 1"
  - name: Phase 3 — Verify
    artifact: a passing verification command and its output
    acceptance: a \`bash\` or \`test\` command exits 0 and the output is shown
imports: []
can_execute_without_mcp: true
tags:
  - tag-one
  - tag-two
  - tag-three
layer: 1
complexity: medium
