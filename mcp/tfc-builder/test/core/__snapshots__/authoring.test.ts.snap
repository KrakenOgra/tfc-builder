priority: 50
owns:
  - domain-responsibility-slug
  - another-responsibility-slug
does_not_own: null
pairs_with: null
requires:
  - spawner-mcp
  - mind-mcp
sharp_edges:
  - id: first-gotcha-slug
    summary: "One line: what goes wrong"
    severity: critical
    situation: When this fires — be specific about the trigger condition
    why: |
      Root cause explanation. Why does this happen? What assumption is violated?
      Two to four sentences.
    solution: |
      Step-by-step fix. Be concrete. Include code/command if relevant.
    symptoms:
      - Observable signal 1 — what the user sees
      - Observable signal 2
    red_flags:
      - Pattern in code/config that predicts this will happen
  - id: second-gotcha-slug
    summary: Another gotcha
    severity: high
    situation: When this fires
    why: Root cause
    solution: Fix
    symptoms:
      - Signal
    red_flags:
      - Pattern
skill_chain:
  - skill: realthink
    min_level: L3
required_sections:
  - "## PHASE 1"
  - "## HYPOTHESIS (falsifiable):"
  - "## ROOT CAUSE:"
scaffold_template: |
  ## PHASE 1 — REPRODUCE

  ## HYPOTHESIS (falsifiable):

  ## ROOT CAUSE:

  ## FIX DESIGN:
phases:
  - name: Phase 1 — Ground
    artifact: a GROUND block naming actor + precondition + evidence
